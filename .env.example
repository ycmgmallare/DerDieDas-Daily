# Email automation — environment variables (copy to .env and fill in).
# .env is gitignored; never commit real keys. On Render/Vercel, set these in the
# dashboard instead of committing them.

# --- Identity ---------------------------------------------------------------
BRAND_NAME=Daily Email       # shown in the email masthead, footer, and console
CONTENT_FILE=content.md      # the email body source (markdown or .json). Another
                             # skill (e.g. /write-post) can write this file.

# --- Mode -------------------------------------------------------------------
# personal = the email is sent to YOUR ONE address (set via /admin or RESEND_TO).
#            Works on Resend's sandbox sender. No subscribers, no unsubscribe.
# domain   = it fans out to every active subscriber collected via /signup, each
#            with a tokenized unsubscribe link. Needs a Resend-verified domain
#            + PUBLIC_BASE_URL.
EMAIL_AUDIENCE=personal      # personal | domain

# --- Database (Supabase) ----------------------------------------------------
# Project URL + service_role key. Run schema.sql once in the SQL editor first.
# Needed for subscribers, the personal-recipient setting, and unsubscribe.
SUPABASE_URL=
SUPABASE_KEY=

# --- Email (Resend, default) ------------------------------------------------
# RESEND_FROM must be a verified-domain address for domain mode; the default
# "onboarding@resend.dev" sandbox sender only reaches the Resend account owner
# (fine for personal mode). RESEND_TO is the personal-mode recipient + fallback.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
RESEND_TO=

# Gmail SMTP (alternative provider — only needed if EMAIL_PROVIDER=gmail).
GMAIL_USER=
GMAIL_APP_PASSWORD=

EMAIL_PROVIDER=resend         # gmail | resend

# --- Web console auth + cron (used by app.js / api/cron.js when deployed) ----
CONSOLE_USER=admin            # Basic-Auth username for the deployed console
CONSOLE_PASSWORD=             # set on deploy to lock the console; blank = open (local)
CRON_SECRET=                  # shared secret the cron sends to /api/cron
# Public base URL of the deployed app, e.g. https://your-app.vercel.app — used to
# build unsubscribe links in domain mode. Leave blank locally (links are omitted).
PUBLIC_BASE_URL=

# --- Schedule (local scheduler.mjs only; cloud uses render.yaml/vercel.json) -
SEND_CRON=0 7 * * *           # 7:00 AM daily
SEND_TZ=Asia/Manila           # cron timezone + console date labels
